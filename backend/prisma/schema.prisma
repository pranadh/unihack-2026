generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SongRequestStatus {
  queued
  processing
  complete
  failed
}

enum LogLevel {
  debug
  info
  warn
  error
}

model User {
  id               String            @id @default(cuid())
  email            String?           @unique
  displayName      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  songRequests     SongRequest[]
  playbackSessions PlaybackSession[]
  authAccounts     AuthAccount[]
  authSessions     AuthSession[]
}

model SongRequest {
  id               String             @id @default(cuid())
  userId           String?
  guestSessionHash String?
  youtubeUrl       String
  youtubeVideoId   String
  status           SongRequestStatus  @default(queued)
  createdAt        DateTime           @default(now())
  completedAt      DateTime?
  errorMessage     String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  chordTimeline    ChordTimeline?
  playbackSessions PlaybackSession[]
  systemLogs       SystemLog[]

  @@index([userId, createdAt])
  @@index([guestSessionHash, createdAt])
  @@index([youtubeVideoId])
  @@index([status])
}

model ChordTimeline {
  id                String       @id @default(cuid())
  songRequestId     String       @unique
  version           Int          @default(1)
  confidenceSummary String?
  durationSeconds   Float
  generatedAt       DateTime     @default(now())
  songRequest       SongRequest  @relation(fields: [songRequestId], references: [id], onDelete: Cascade)
  chordEvents       ChordEvent[]
}

model ChordEvent {
  id           String        @id @default(cuid())
  timelineId   String
  startTimeSec Float
  endTimeSec   Float
  chordLabel   String
  timeline     ChordTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId, startTimeSec])
}

model PlaybackSession {
  id                String      @id @default(cuid())
  userId            String?
  songRequestId     String
  startedAt         DateTime    @default(now())
  endedAt           DateTime?
  completionPercent Float       @default(0)
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  songRequest       SongRequest @relation(fields: [songRequestId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([songRequestId, startedAt])
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SystemLog {
  id          String      @id @default(cuid())
  requestId   String
  songRequestId String?
  level       LogLevel    @default(info)
  code        String?
  message     String
  createdAt   DateTime    @default(now())
  songRequest SongRequest? @relation(fields: [songRequestId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@index([songRequestId])
  @@index([level, createdAt])
}
